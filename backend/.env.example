NODE_ENV=development
PORT=5000


DATABASE_URL="mysql://root:password@localhost:3306/true_tilawah"
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-different-long-random-string
JWT_REFRESH_EXPIRES_IN=30d


BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100


CORS_ORIGIN=http://localhost:3000
STORAGE_BUCKET_NAME=true-tilawah-audio
STORAGE_REGION=us-east-1

# ── AI service connection ──────────────────────────────────
# For local dev (Docker Compose), set HOST/PORT below. For HF Space deployment,
# set AI_SERVICE_WSS_URL to the full wss:// URL and AI_SERVICE_AUTH_TOKEN to the
# bearer token configured in the Space's secrets. WSS_URL overrides HOST/PORT.
AI_SERVICE_HOST=localhost
AI_SERVICE_PORT=8000
AI_SERVICE_WS_PATH=/ws/evaluate
AI_SERVICE_TIMEOUT_MS=10000
# AI_SERVICE_WSS_URL=wss://your-user-truetilawah-asr.hf.space/ws/evaluate
# AI_SERVICE_AUTH_TOKEN=
